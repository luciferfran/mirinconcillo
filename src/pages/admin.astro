---
export const prerender = false;

import Layout from '../layouts/Layout.astro';

const ADMIN_PASSWORD = 'rinconcillo2024';

const isLoggedIn = Astro.cookies.get('admin_auth')?.value === ADMIN_PASSWORD;
const error = Astro.url.searchParams.get('error');
const saved = Astro.url.searchParams.get('saved');
---

<Layout title="Admin">
  <div class="pt-24 pb-12 bg-stone-100 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      {!isLoggedIn ? (
        <div class="max-w-md mx-auto bg-white p-8 rounded-lg shadow-md mt-20">
          <h1 class="font-serif text-2xl text-stone-800 mb-6 text-center">Acceso Admin</h1>
          {error && (
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
              Contraseña incorrecta
            </div>
          )}
          <form method="post" action="/api/login">
            <input type="password" name="password" placeholder="Contraseña" 
              class="w-full px-4 py-2 border border-stone-300 rounded-lg mb-4 focus:outline-none focus:ring-2 focus:ring-amber-500" required />
            <button type="submit" class="w-full bg-amber-700 text-white py-2 rounded-lg hover:bg-amber-800">
              Entrar
            </button>
          </form>
          <p class="text-center text-stone-500 text-sm mt-4">
            Contacta con el administrador para obtener la contraseña
          </p>
        </div>
      ) : (
        <div>
          <div class="flex justify-between items-center mb-8">
            <h1 class="font-serif text-3xl text-stone-800">Panel de Administración</h1>
            <a href="/api/logout" class="text-stone-600 hover:text-stone-800">Cerrar sesión</a>
          </div>

          {saved && (
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
              Cambios guardados correctamente
            </div>
          )}

          <div class="bg-white p-6 rounded-lg shadow-md mb-6">
            <h2 class="font-semibold text-stone-800 mb-4">Editar contenido del sitio</h2>
            <p class="text-stone-600 text-sm mb-4">
              Los cambios se guardan automáticamente en el archivo JSON. 
              Para que los cambios se reflejen en la web, rebuilda el sitio.
            </p>
            <form method="post" action="/api/save-content">
              <textarea name="content" id="editor" rows="30" 
                class="w-full px-4 py-2 border border-stone-300 rounded-lg font-mono text-sm focus:outline-none focus:ring-2 focus:ring-amber-500"></textarea>
              <button type="submit" class="mt-4 bg-amber-700 text-white px-6 py-2 rounded-lg hover:bg-amber-800">
                Guardar cambios
              </button>
            </form>
          </div>

          <div class="bg-white p-6 rounded-lg shadow-md">
            <h2 class="font-semibold text-stone-800 mb-4">Notas</h2>
            <ul class="text-stone-600 text-sm space-y-2">
              <li>• La contraseña por defecto es: <code class="bg-stone-100 px-2 py-1 rounded">rinconcillo2024</code></li>
              <li>• El formato es JSON, mantén la estructura</li>
              <li>• Después de guardar, los cambios se ven al hacer <code class="bg-stone-100 px-2 py-1 rounded">npm run build</code></li>
            </ul>
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>

<script define:vars={{ isLoggedIn }}>
  if (isLoggedIn) {
    fetch('/api/content')
      .then(r => r.json())
      .then(data => {
        document.getElementById('editor').value = JSON.stringify(data, null, 2);
      });
  }
</script>
