---
import Layout from '../layouts/Layout.astro';

const galleryImages = [
  { src: 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80', alt: 'Casa rural exterior', category: 'La Casa' },
  { src: 'https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&w=800&q=80', alt: 'Sala de estar', category: 'La Casa' },
  { src: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=800&q=80', alt: 'Dormitorio', category: 'La Casa' },
  { src: 'https://images.unsplash.com/photo-1600566753086-00f18fb6b3ea?auto=format&fit=crop&w=800&q=80', alt: 'Baño', category: 'La Casa' },
  { src: 'https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?auto=format&fit=crop&w=800&q=80', alt: 'Cocina', category: 'La Casa' },
  { src: 'https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&w=800&q=80', alt: 'Chimenea', category: 'La Casa' },
  { src: 'https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?auto=format&fit=crop&w=800&q=80', alt: 'Comedor', category: 'La Casa' },
  { src: 'https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?auto=format&fit=crop&w=800&q=80', alt: 'Patio', category: 'La Casa' },
  { src: 'https://images.unsplash.com/photo-1518780664697-55e3ad937233?auto=format&fit=crop&w=800&q=80', alt: 'Entorno natural', category: 'Entorno' },
  { src: 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=800&q=80', alt: 'Montaña', category: 'Entorno' },
  { src: 'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=800&q=80', alt: 'Paisaje', category: 'Entorno' },
  { src: 'https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=800&q=80', alt: 'Río', category: 'Entorno' },
];
---

<Layout title="Galería">
  <section class="pt-24 pb-12 bg-stone-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-serif text-5xl text-stone-800 mb-4">Galería</h1>
      <p class="text-stone-600 max-w-2xl">
        Descubre la belleza de Mi Rinconcillo y sus alrededores
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {galleryImages.map((img, index) => (
          <div class="group relative overflow-hidden rounded-lg cursor-pointer">
            <img 
              src={img.src} 
              alt={img.alt}
              class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-all duration-300 flex items-end">
              <div class="p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <p class="text-white text-sm font-medium">{img.alt}</p>
                <p class="text-white/70 text-xs">{img.category}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-stone-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-3xl text-stone-800 mb-8 text-center">Explora los alrededores</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white p-6 rounded-lg shadow-md">
          <h3 class="font-serif text-xl text-stone-800 mb-3">Pedraza</h3>
          <p class="text-stone-600 text-sm">
            Uno de los pueblos más bonitos de España. Conocido por su plaza porticada y su castillo del siglo XV.
          </p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md">
          <h3 class="font-serif text-xl text-stone-800 mb-3">Hoces del Río Duratón</h3>
          <p class="text-stone-600 text-sm">
            Impresionante desfiladero con cuevas de interés geológico. Ideal para rutas de senderismo y observación de buitres.
          </p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md">
          <h3 class="font-serif text-xl text-stone-800 mb-3">Valleruela de Pedraza</h3>
          <p class="text-stone-600 text-sm">
            Nuestro pueblo. Tranquilo y auténtico, perfecto para desconectar y disfrutar de la naturaleza.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
