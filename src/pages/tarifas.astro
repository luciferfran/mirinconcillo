---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tarifas">
  <section class="pt-24 pb-12 bg-stone-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-serif text-5xl text-stone-800 mb-4">Tarifas y Ofertas</h1>
      <p class="text-stone-600 max-w-2xl">
        Precios clearos para tu escapada rural. Registro Turismo CRA 40/385
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="bg-gradient-to-br from-amber-50 to-stone-100 p-8 rounded-2xl mb-8">
          <h2 class="font-serif text-2xl text-stone-800 mb-6 text-center">Fin de semana</h2>
          <div class="space-y-4">
            <div class="flex justify-between items-center p-4 bg-white rounded-lg shadow-sm">
              <div>
                <p class="font-semibold text-stone-800">4-5 personas</p>
                <p class="text-stone-500 text-sm">2 noches</p>
              </div>
              <p class="text-2xl font-bold text-amber-700">350€</p>
            </div>
            <div class="flex justify-between items-center p-4 bg-white rounded-lg shadow-sm">
              <div>
                <p class="font-semibold text-stone-800">2-3 personas</p>
                <p class="text-stone-500 text-sm">2 noches</p>
              </div>
              <p class="text-2xl font-bold text-amber-700">300€</p>
            </div>
          </div>
          <p class="text-center text-stone-500 text-sm mt-4">Incluye desayuno del primer día</p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 mb-8">
          <div class="bg-stone-50 p-8 rounded-2xl">
            <h3 class="font-serif text-xl text-stone-800 mb-4">Puentes</h3>
            <p class="text-3xl font-bold text-amber-700 mb-2">440€</p>
            <p class="text-stone-600 text-sm">3 días, casa completa</p>
            <p class="text-stone-500 text-xs mt-2">Consultar mínimo de noches</p>
          </div>
          <div class="bg-stone-50 p-8 rounded-2xl">
            <h3 class="font-serif text-xl text-stone-800 mb-4">Concierto de las Velas</h3>
            <p class="text-stone-600 text-sm mb-2">Primero y segundo finde de julio</p>
            <p class="text-xl font-bold text-amber-700">380€ (4-5 pers)</p>
            <p class="text-lg text-amber-700">350€ (2-3 pers)</p>
            <p class="text-stone-500 text-xs mt-2">2 días</p>
          </div>
        </div>

        <div class="bg-stone-900 text-white p-8 rounded-2xl">
          <h3 class="font-serif text-xl mb-4">Fechas especiales</h3>
          <div class="grid md:grid-cols-2 gap-4">
            <div class="flex justify-between items-center p-3 bg-stone-800 rounded-lg">
              <span>Nochebuena / Nochevieja / Reyes</span>
              <span class="font-bold text-amber-400">350-380€</span>
            </div>
          </div>
          <p class="text-stone-400 text-sm mt-4">Consultar ofertas de verano</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-stone-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <h2 class="font-serif text-2xl text-stone-800 mb-6">Incluido en el precio</h2>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="flex items-center gap-3 bg-white p-4 rounded-lg">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-stone-700">Leña para chimenea</span>
          </div>
          <div class="flex items-center gap-3 bg-white p-4 rounded-lg">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-stone-700">Carbón para barbacoa</span>
          </div>
          <div class="flex items-center gap-3 bg-white p-4 rounded-lg">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-stone-700">Desayuno primer día</span>
          </div>
          <div class="flex items-center gap-3 bg-white p-4 rounded-lg">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <span class="text-stone-700">10% IVA</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-amber-700 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-serif text-3xl mb-4">¿Tienes preguntas?</h2>
      <p class="mb-8 opacity-90">No dudes en contactarnos para reservar o resolver cualquier duda</p>
      <a href="/contacto" class="inline-block bg-white text-amber-700 hover:bg-stone-100 px-8 py-3 transition-all duration-300 font-semibold">
        Contactar
      </a>
    </div>
  </section>
</Layout>
